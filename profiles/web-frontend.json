{
    "id": "web-frontend",
    "name": "Web Frontend Development",
    "description": "HTML/CSS/JavaScript and modern frameworks (React, Vue, Svelte)",
    "icon": "web",
    "category": "web",

    "requiredPlugins": [
        "org.exorcist.js-language",
        "org.exorcist.web-tools",
        "org.exorcist.git",
        "org.exorcist.terminal",
        "org.exorcist.search"
    ],
    "optionalPlugins": [
        "org.exorcist.build",
        "org.exorcist.testing"
    ],
    "disabledPlugins": [],
    "deferredPlugins": [],

    "detection": [
        { "type": "fileExists", "pattern": "package.json", "weight": 2 },
        { "type": "fileExists", "pattern": "*.html", "weight": 1 },
        { "type": "fileExists", "pattern": "*.jsx", "weight": 3 },
        { "type": "fileExists", "pattern": "*.tsx", "weight": 3 },
        { "type": "fileExists", "pattern": "*.vue", "weight": 3 },
        { "type": "fileExists", "pattern": "*.svelte", "weight": 3 },
        { "type": "fileExists", "pattern": "vite.config.*", "weight": 3 },
        { "type": "directoryExists", "pattern": "node_modules", "weight": 1 }
    ],
    "detectionThreshold": 3,

    "dockDefaults": [
        { "id": "ProjectDock", "visible": true },
        { "id": "SearchDock", "visible": false },
        { "id": "GitDock", "visible": false },
        { "id": "TerminalDock", "visible": true },
        { "id": "ProblemsDock", "visible": true },
        { "id": "OutputDock", "visible": false },
        { "id": "RunDock", "visible": false }
    ],

    "settings": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    }
}
