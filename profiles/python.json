{
    "id": "python",
    "name": "Python Development",
    "description": "Python projects with virtualenv, pytest, and LSP",
    "icon": "python",
    "category": "scripting",

    "requiredPlugins": [
        "org.exorcist.python-language",
        "org.exorcist.testing",
        "org.exorcist.debug",
        "org.exorcist.git",
        "org.exorcist.terminal",
        "org.exorcist.search"
    ],
    "optionalPlugins": [
        "org.exorcist.build"
    ],
    "disabledPlugins": [
        "org.exorcist.qt-tools"
    ],
    "deferredPlugins": [
        "org.exorcist.debug",
        "org.exorcist.testing"
    ],

    "detection": [
        { "type": "fileExists", "pattern": "requirements.txt", "weight": 3 },
        { "type": "fileExists", "pattern": "pyproject.toml", "weight": 3 },
        { "type": "fileExists", "pattern": "setup.py", "weight": 3 },
        { "type": "fileExists", "pattern": "*.py", "weight": 2 },
        { "type": "directoryExists", "pattern": "venv", "weight": 2 },
        { "type": "directoryExists", "pattern": ".venv", "weight": 2 }
    ],
    "detectionThreshold": 3,

    "dockDefaults": [
        { "id": "ProjectDock", "visible": true },
        { "id": "SearchDock", "visible": false },
        { "id": "GitDock", "visible": false },
        { "id": "TerminalDock", "visible": true },
        { "id": "ProblemsDock", "visible": true },
        { "id": "OutputDock", "visible": false },
        { "id": "RunDock", "visible": false },
        { "id": "DebugDock", "visible": false },
        { "id": "TestExplorerDock", "visible": true }
    ],

    "settings": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    }
}
