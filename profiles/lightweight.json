{
    "id": "lightweight",
    "name": "Lightweight Text Editing",
    "description": "Minimal mode — fast startup, basic editing only",
    "icon": "edit",
    "category": "minimal",

    "requiredPlugins": [],
    "optionalPlugins": [
        "org.exorcist.terminal",
        "org.exorcist.search"
    ],
    "disabledPlugins": [
        "org.exorcist.cpp-language",
        "org.exorcist.build",
        "org.exorcist.debug",
        "org.exorcist.testing",
        "org.exorcist.github",
        "org.exorcist.remote"
    ],
    "deferredPlugins": [],

    "detection": [],
    "detectionThreshold": 999,

    "dockDefaults": [
        { "id": "ProjectDock", "visible": true },
        { "id": "SearchDock", "visible": false },
        { "id": "GitDock", "visible": false },
        { "id": "TerminalDock", "visible": false },
        { "id": "ProblemsDock", "visible": false },
        { "id": "OutputDock", "visible": false },
        { "id": "RunDock", "visible": false }
    ],

    "settings": {
        "editor.minimap": false,
        "editor.indentGuides": true
    }
}
