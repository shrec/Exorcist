{
    "id": "org.exorcist.testing",
    "name": "Testing",
    "version": "1.0.0",
    "description": "CTest-based test discovery, execution, and explorer panel",
    "author": "Exorcist Team",
    "license": "MIT",
    "layer": "cpp-sdk",
    "category": "core",
    "activationEvents": [
        "workspaceContains:CTestTestfile.cmake",
        "workspaceContains:CMakeLists.txt"
    ],
    "contributions": {
        "views": [
            {
                "id": "TestExplorerDock",
                "title": "Test Explorer",
                "location": "bottom"
            }
        ],
        "commands": [
            {
                "id": "testing.discover",
                "title": "Discover Tests",
                "category": "Test"
            },
            {
                "id": "testing.runAll",
                "title": "Run All Tests",
                "category": "Test"
            }
        ]
    }
}
