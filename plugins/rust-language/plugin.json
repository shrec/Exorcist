{
    "id": "org.exorcist.rust-language",
    "name": "Rust Language Support",
    "version": "1.0.0",
    "description": "Rust language support via rust-analyzer.",
    "author": "Exorcist",
    "license": "MIT",
    "layer": "cpp-sdk",
    "category": "language",
    "activationEvents": [
        "workspaceContains:Cargo.toml",
        "workspaceContains:*.rs"
    ],
    "contributions": {
        "languages": [
            {
                "id": "rust",
                "name": "Rust",
                "extensions": [".rs"],
                "mimeTypes": ["text/x-rustsrc"],
                "lspCommand": "rust-analyzer"
            }
        ],
        "commands": [
            { "id": "rust.goToDefinition",       "title": "Go to Definition" },
            { "id": "rust.goToDeclaration",       "title": "Go to Declaration" },
            { "id": "rust.findReferences",        "title": "Find All References" },
            { "id": "rust.renameSymbol",          "title": "Rename Symbol" },
            { "id": "rust.formatDocument",        "title": "Format Document" },
            { "id": "rust.gotoWorkspaceSymbol",   "title": "Go to Symbol in Workspace" },
            { "id": "rust.restartLanguageServer", "title": "Restart Language Server" },
            { "id": "rust.cargoBuild",            "title": "Cargo Build" },
            { "id": "rust.cargoRun",              "title": "Cargo Run" },
            { "id": "rust.cargoTest",             "title": "Cargo Test" },
            { "id": "rust.cargoCheck",            "title": "Cargo Check" },
            { "id": "rust.cargoClippy",           "title": "Cargo Clippy" },
            { "id": "rust.cargoClean",            "title": "Cargo Clean" },
            { "id": "rust.openCargoToml",         "title": "Open Cargo.toml" }
        ]
    }
}