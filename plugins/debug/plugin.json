{
    "id":          "org.exorcist.debug",
    "name":        "Debug",
    "version":     "1.0.0",
    "description": "GDB/MI debug adapter, debug panel, watch tree, quick watch dialog",
    "category":    "core",
    "activationEvents": [
        "workspaceContains:CMakeLists.txt",
        "workspaceContains:Makefile",
        "workspaceContains:Cargo.toml"
    ],
    "contributions": {
        "views": [
            {
                "id": "DebugDock",
                "title": "Debug",
                "location": "bottom"
            }
        ],
        "commands": [
            { "id": "debug.launch",    "title": "Launch Debugger" },
            { "id": "debug.continue",  "title": "Continue Execution" },
            { "id": "debug.stepOver",  "title": "Step Over" },
            { "id": "debug.stepInto",  "title": "Step Into" },
            { "id": "debug.stepOut",   "title": "Step Out" },
            { "id": "debug.terminate", "title": "Terminate Debug Session" }
        ]
    }
}
